# ── PREMTEK 裝機戰情室 — 環境變數範本 ────────────────────────────────────────
# 複製此檔案為 .env.local，填入實際值後啟動開發伺服器。
# 請勿將 .env.local 提交到 git（已在 .gitignore 中排除）。
#
# Firebase 設定：Firebase Console → 您的專案 → 專案設定 → 您的應用程式
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY="__YOUR_API_KEY__"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="__YOUR_PROJECT__.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="__YOUR_PROJECT__"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="__YOUR_PROJECT__.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="__YOUR_SENDER_ID__"
NEXT_PUBLIC_FIREBASE_APP_ID="__YOUR_APP_ID__"

# 選用：GA4 Measurement ID（如不使用可留空）
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 選用：覆寫 src/version.ts 的版號（CI/CD 自動注入用，平時不需設定）
# NEXT_PUBLIC_APP_VERSION=1.0.4
